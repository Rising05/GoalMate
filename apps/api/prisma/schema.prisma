generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "mysql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  DISABLED
  DELETED
}

enum MembershipPlan {
  FREE
  PRO
}

enum MembershipStatus {
  ACTIVE
  EXPIRED
  MANUAL
}

enum GoalCategory {
  STUDY
  CAREER
  FITNESS
  HABIT
  CUSTOM
}

enum GoalStatus {
  DRAFT
  GENERATING_PLAN
  WAITING_CONFIRMATION
  ACTIVE
  AT_RISK
  REPLANNING
  COMPLETED
  FAILED
  GENERATION_FAILED
}

enum CheckinStatus {
  PENDING
  SUBMITTED
  SCORING
  SCORED
  SCORE_FAILED
  APPEALING
  RESCORED
  APPEAL_REJECTED
}

enum AiJobStatus {
  QUEUED
  RUNNING
  RETRYING
  SUCCEEDED
  FAILED
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  displayName  String?
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  membership Membership?
  goals      Goal[]
  aiJobs     AiJob[]

  @@map("users")
}

model Membership {
  id        String           @id @default(cuid())
  userId    String           @unique
  plan      MembershipPlan   @default(FREE)
  status    MembershipStatus @default(ACTIVE)
  expiresAt DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("memberships")
}

model Goal {
  id          String       @id @default(cuid())
  userId      String
  title       String
  description String       @db.Text
  category    GoalCategory @default(CUSTOM)
  status      GoalStatus   @default(DRAFT)
  startDate   DateTime
  endDate     DateTime
  timezone    String       @default("Asia/Shanghai")
  toleranceDaysAllowed Int @default(0)
  toleranceDaysUsed    Int @default(0)
  dailyTimeBudgetMinutes Int?
  currentBaseline String?  @db.Text
  constraints     String?  @db.Text
  finalReward     String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan       Plan?
  milestones Milestone[]
  dailyTasks DailyTask[]
  checkins   Checkin[]
  aiJobs     AiJob[]

  @@index([userId, status])
  @@map("goals")
}

model Plan {
  id        String   @id @default(cuid())
  goalId    String   @unique
  version   Int      @default(1)
  summary   String   @db.Text
  isActive  Boolean  @default(false)
  confirmedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  goal        Goal         @relation(fields: [goalId], references: [id], onDelete: Cascade)
  weeklyPlans WeeklyPlan[]

  @@map("plans")
}

model Milestone {
  id          String   @id @default(cuid())
  goalId      String
  title       String
  description String?  @db.Text
  targetDate  DateTime
  rewardText  String?  @db.Text
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId, targetDate])
  @@map("milestones")
}

model WeeklyPlan {
  id        String   @id @default(cuid())
  planId    String
  weekIndex Int
  title     String
  summary   String   @db.Text
  startsOn  DateTime
  endsOn    DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  plan       Plan        @relation(fields: [planId], references: [id], onDelete: Cascade)
  dailyTasks DailyTask[]

  @@unique([planId, weekIndex])
  @@map("weekly_plans")
}

model DailyTask {
  id          String   @id @default(cuid())
  goalId      String
  weeklyPlanId String?
  taskDate    DateTime
  title       String
  description String   @db.Text
  plannedMinutes Int?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  goal       Goal        @relation(fields: [goalId], references: [id], onDelete: Cascade)
  weeklyPlan WeeklyPlan? @relation(fields: [weeklyPlanId], references: [id], onDelete: SetNull)
  checkins   Checkin[]

  @@index([goalId, taskDate])
  @@map("daily_tasks")
}

model Checkin {
  id             String        @id @default(cuid())
  userId         String
  goalId         String
  dailyTaskId    String?
  status         CheckinStatus @default(SUBMITTED)
  content        String        @db.Text
  investedMinutes Int?
  submittedAt    DateTime     @default(now())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  goal      Goal       @relation(fields: [goalId], references: [id], onDelete: Cascade)
  dailyTask DailyTask? @relation(fields: [dailyTaskId], references: [id], onDelete: SetNull)
  aiScore   AiScore?

  @@index([goalId, submittedAt])
  @@map("checkins")
}

model AiScore {
  id        String   @id @default(cuid())
  checkinId String  @unique
  totalScore Int
  dimensions Json
  evidence   Json
  summary    String @db.Text
  suggestion String @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  checkin Checkin @relation(fields: [checkinId], references: [id], onDelete: Cascade)

  @@map("ai_scores")
}

model AiJob {
  id        String      @id @default(cuid())
  userId    String
  goalId    String?
  type      String
  status    AiJobStatus @default(QUEUED)
  attempts  Int         @default(0)
  payload   Json
  result    Json?
  error     String?     @db.Text
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal Goal? @relation(fields: [goalId], references: [id], onDelete: SetNull)

  @@index([status, type])
  @@index([userId, createdAt])
  @@map("ai_jobs")
}
