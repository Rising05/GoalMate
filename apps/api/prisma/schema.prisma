generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "mysql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  DISABLED
  DELETED
}

enum MembershipPlan {
  FREE
  PRO
}

enum MembershipStatus {
  ACTIVE
  EXPIRED
  MANUAL
}

enum GoalCategory {
  STUDY
  CAREER
  FITNESS
  HABIT
  CUSTOM
}

enum GoalStatus {
  DRAFT
  GENERATING_PLAN
  WAITING_CONFIRMATION
  ACTIVE
  AT_RISK
  REPLANNING
  COMPLETED
  FAILED
  GENERATION_FAILED
}

enum CheckinStatus {
  PENDING
  SUBMITTED
  SCORING
  SCORED
  SCORE_FAILED
  APPEALING
  RESCORED
  APPEAL_REJECTED
}

enum AiJobStatus {
  QUEUED
  RUNNING
  RETRYING
  SUCCEEDED
  FAILED
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  displayName  String?
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  membership Membership?
  goals      Goal[]
  aiJobs     AiJob[]
  notificationPreference NotificationPreference?
  emailLogs   EmailLog[]
  scoreAppeals ScoreAppeal[]
  adminProfile AdminUser?
  auditLogs AuditLog[]

  @@map("users")
}

model AdminUser {
  id        String   @id @default(cuid())
  userId    String   @unique
  role      String   @default("OPERATOR")
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([role, status])
  @@map("admin_users")
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String
  action      String
  targetType  String
  targetId    String?
  reason      String?  @db.Text
  metadata    Json
  createdAt   DateTime @default(now())

  actor User @relation(fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
  @@index([targetType, targetId])
  @@map("audit_logs")
}

model SystemConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("system_configs")
}

model NotificationPreference {
  id            String   @id @default(cuid())
  userId        String   @unique
  enabled       Boolean  @default(true)
  reminderTime  String   @default("09:00")
  reminderTypes Json
  timezone      String   @default("Asia/Shanghai")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model EmailLog {
  id            String   @id @default(cuid())
  userId        String
  goalId        String?
  type          String
  recipientEmail String
  subject       String
  content       String   @db.Text
  status        String   @default("QUEUED")
  error         String?  @db.Text
  scheduledFor  DateTime?
  sentAt        DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status, type])
  @@map("email_logs")
}

model Membership {
  id        String           @id @default(cuid())
  userId    String           @unique
  plan      MembershipPlan   @default(FREE)
  status    MembershipStatus @default(ACTIVE)
  expiresAt DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("memberships")
}

model Goal {
  id                     String       @id @default(cuid())
  userId                 String
  title                  String
  description            String       @db.Text
  category               GoalCategory @default(CUSTOM)
  status                 GoalStatus   @default(DRAFT)
  startDate              DateTime
  endDate                DateTime
  timezone               String       @default("Asia/Shanghai")
  toleranceDaysAllowed   Int          @default(0)
  toleranceDaysUsed      Int          @default(0)
  dailyTimeBudgetMinutes Int?
  currentBaseline        String?      @db.Text
  constraints            String?      @db.Text
  finalReward            String?      @db.Text
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan            Plan?
  milestones      Milestone[]
  dailyTasks      DailyTask[]
  checkins        Checkin[]
  aiJobs          AiJob[]
  deviationEvents DeviationEvent[]
  rewardCards     RewardCard[]
  healthSnapshots HealthSnapshot[]
  failureReport   FailureReport?

  @@index([userId, status])
  @@map("goals")
}

model FailureReport {
  id                 String   @id @default(cuid())
  goalId             String   @unique
  reasonAnalysis     String   @db.Text
  brokenStreakTimeline Json
  lowScoreTasks      Json
  keyDeviationNodes  Json
  suggestion         String   @db.Text
  restartGoalDraft   Json
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@map("failure_reports")
}

model RewardCard {
  id          String   @id @default(cuid())
  goalId      String
  title       String
  description String?  @db.Text
  cardType    String   @default("TEXT")
  sourceType  String   @default("CUSTOM")
  sourceRefId String?
  imageUrl    String?  @db.Text
  linkUrl     String?  @db.Text
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId, sortOrder])
  @@index([goalId, sourceType])
  @@map("reward_cards")
}

model Plan {
  id          String    @id @default(cuid())
  goalId      String    @unique
  version     Int       @default(1)
  summary     String    @db.Text
  isActive    Boolean   @default(false)
  confirmedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  goal        Goal         @relation(fields: [goalId], references: [id], onDelete: Cascade)
  weeklyPlans WeeklyPlan[]

  @@map("plans")
}

model Milestone {
  id          String   @id @default(cuid())
  goalId      String
  title       String
  description String?  @db.Text
  targetDate  DateTime
  rewardText  String?  @db.Text
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId, targetDate])
  @@map("milestones")
}

model WeeklyPlan {
  id        String   @id @default(cuid())
  planId    String
  weekIndex Int
  title     String
  summary   String   @db.Text
  startsOn  DateTime
  endsOn    DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  plan       Plan        @relation(fields: [planId], references: [id], onDelete: Cascade)
  dailyTasks DailyTask[]

  @@unique([planId, weekIndex])
  @@map("weekly_plans")
}

model DailyTask {
  id                String   @id @default(cuid())
  goalId            String
  weeklyPlanId      String?
  sourceDailyTaskId String?
  deviationEventId  String?
  taskDate          DateTime
  title             String
  description       String   @db.Text
  plannedMinutes    Int?
  taskType          String   @default("NORMAL")
  rescueReason      String?  @db.Text
  rescueTriggerCode String?
  rescueRiskLevel   String?
  status            String   @default("PENDING")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  goal           Goal            @relation(fields: [goalId], references: [id], onDelete: Cascade)
  weeklyPlan     WeeklyPlan?     @relation(fields: [weeklyPlanId], references: [id], onDelete: SetNull)
  deviationEvent DeviationEvent? @relation(fields: [deviationEventId], references: [id], onDelete: SetNull)
  checkins       Checkin[]

  @@index([goalId, taskDate])
  @@index([goalId, taskType, status])
  @@index([sourceDailyTaskId])
  @@index([deviationEventId])
  @@map("daily_tasks")
}

model DeviationEvent {
  id                  String   @id @default(cuid())
  goalId              String
  sourceDailyTaskId   String?
  riskLevel           String
  primaryReasonCode   String?
  primaryReasonLabel  String?
  primaryReasonDetail String?  @db.Text
  reasons             Json
  metrics             Json
  detectedAt          DateTime @default(now())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  goal        Goal        @relation(fields: [goalId], references: [id], onDelete: Cascade)
  rescueTasks DailyTask[]

  @@index([goalId, detectedAt])
  @@index([goalId, riskLevel])
  @@index([sourceDailyTaskId])
  @@map("deviation_events")
}

model HealthSnapshot {
  id                String   @id @default(cuid())
  goalId            String
  date              DateTime
  healthScore       Int
  deviationEventId  String?
  completionMetrics Json
  rescueMetrics     Json
  riskLevel         String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@unique([goalId, date])
  @@index([goalId, date])
  @@index([goalId, riskLevel])
  @@index([deviationEventId])
  @@map("health_snapshots")
}

model Checkin {
  id              String        @id @default(cuid())
  userId          String
  goalId          String
  dailyTaskId     String?
  status          CheckinStatus @default(SUBMITTED)
  content         String        @db.Text
  investedMinutes Int?
  submittedAt     DateTime      @default(now())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  goal      Goal       @relation(fields: [goalId], references: [id], onDelete: Cascade)
  dailyTask DailyTask? @relation(fields: [dailyTaskId], references: [id], onDelete: SetNull)
  aiScore   AiScore?
  scoreAppeals ScoreAppeal[]

  @@index([goalId, submittedAt])
  @@map("checkins")
}

model ScoreAppeal {
  id            String   @id @default(cuid())
  userId        String
  checkinId     String
  reason        String   @db.Text
  addedFacts    String   @db.Text
  status        String   @default("PENDING")
  originalScore Int
  newScore      Int?
  evidence      Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  checkin Checkin @relation(fields: [checkinId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([checkinId, createdAt])
  @@map("score_appeals")
}

model AiScore {
  id         String   @id @default(cuid())
  checkinId  String   @unique
  totalScore Int
  dimensions Json
  evidence   Json
  summary    String   @db.Text
  suggestion String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  checkin Checkin @relation(fields: [checkinId], references: [id], onDelete: Cascade)

  @@map("ai_scores")
}

model AiJob {
  id        String      @id @default(cuid())
  userId    String
  goalId    String?
  type      String
  status    AiJobStatus @default(QUEUED)
  attempts  Int         @default(0)
  payload   Json
  result    Json?
  error     String?     @db.Text
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal Goal? @relation(fields: [goalId], references: [id], onDelete: SetNull)

  @@index([status, type])
  @@index([userId, createdAt])
  @@map("ai_jobs")
}
