generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "mysql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  DISABLED
  DELETED
}

enum MembershipPlan {
  FREE
  PRO
}

enum MembershipStatus {
  ACTIVE
  EXPIRED
  MANUAL
}

enum GoalCategory {
  STUDY
  CAREER
  FITNESS
  HABIT
  CUSTOM
  POSTGRAD_EXAM
  CET_4_6
  IELTS_TOEFL
  GPA_IMPROVEMENT
  CERTIFICATION
  CUSTOM_STUDY
}

enum GoalStatus {
  DRAFT
  GENERATING_PLAN
  WAITING_CONFIRMATION
  ACTIVE
  AT_RISK
  REPLANNING
  COMPLETED
  FAILED
  GENERATION_FAILED
}

enum CheckinStatus {
  PENDING
  SUBMITTED
  SCORING
  SCORED
  SCORE_FAILED
  APPEALING
  RESCORED
  APPEAL_REJECTED
}

enum AiJobStatus {
  QUEUED
  RUNNING
  RETRYING
  SUCCEEDED
  FAILED
  CANCELLED
}

model User {
  id                      String     @id @default(cuid())
  email                   String     @unique
  passwordHash            String
  displayName             String?
  status                  UserStatus @default(ACTIVE)
  termsVersion            String?
  termsAcceptedAt         DateTime?
  privacyVersion          String?
  privacyAcceptedAt       DateTime?
  aiDisclosureVersion     String?
  aiDisclosureAcceptedAt  DateTime?
  requiresTermsAcceptance Boolean    @default(false)
  createdAt               DateTime   @default(now())
  updatedAt               DateTime   @updatedAt

  membership             Membership?
  goals                  Goal[]
  aiJobs                 AiJob[]
  notificationPreference NotificationPreference?
  emailLogs              EmailLog[]
  wechatBinding          WechatBinding?
  uploadAssets           UploadAsset[]
  scoreAppeals           ScoreAppeal[]
  adminProfile           AdminUser?
  auditLogs              AuditLog[]
  paymentOrders          PaymentOrder[]
  paymentEvents          PaymentEvent[]
  membershipAudits       MembershipAudit[]       @relation("MembershipAuditUser")
  membershipAuditActions MembershipAudit[]       @relation("MembershipAuditActor")
  entitlements           Entitlement[]
  usageRecords           UsageRecord[]
  quotaBuckets           QuotaBucket[]
  aiCallLogs             AiCallLog[]

  @@map("users")
}

model AdminUser {
  id        String   @id @default(cuid())
  userId    String   @unique
  role      String   @default("OPERATOR")
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([role, status])
  @@map("admin_users")
}

model AuditLog {
  id               String   @id @default(cuid())
  actorUserId      String
  action           String
  targetType       String
  targetId         String?
  reason           String?  @db.Text
  reasonKeyVersion String?
  metadata         Json
  createdAt        DateTime @default(now())

  actor User @relation(fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
  @@index([targetType, targetId])
  @@map("audit_logs")
}

model SystemConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("system_configs")
}

model NotificationPreference {
  id             String   @id @default(cuid())
  userId         String   @unique
  enabled        Boolean  @default(true)
  reminderTime   String   @default("09:00")
  reminderTypes  Json
  channels       Json?
  timezone       String   @default("Asia/Shanghai")
  silentDays     Json?
  examSprintDays Int      @default(14)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model EmailLog {
  id                String    @id @default(cuid())
  traceId           String?
  userId            String
  goalId            String?
  channel           String    @default("EMAIL")
  type              String
  recipientEmail    String
  subject           String
  content           String    @db.Text
  status            String    @default("QUEUED")
  attempts          Int       @default(0)
  provider          String?
  providerMessageId String?
  errorCode         String?
  error             String?   @db.Text
  source            String    @default("MANUAL")
  schedulerRunId    String?
  dedupeKey         String?   @unique
  skipReason        String?   @db.Text
  scheduledFor      DateTime?
  sentAt            DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status, type])
  @@index([channel, status])
  @@index([provider, providerMessageId])
  @@index([source, schedulerRunId])
  @@index([traceId])
  @@map("email_logs")
}

model WechatBinding {
  id                String   @id @default(cuid())
  userId            String   @unique
  openId            String
  openIdHash        String?  @unique
  openIdKeyVersion  String?
  unionId           String?
  unionIdHash       String?  @unique
  unionIdKeyVersion String?
  nickname          String?
  avatarUrl         String?  @db.Text
  status            String   @default("ACTIVE")
  boundAt           DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("wechat_bindings")
}

model UploadAsset {
  id                  String    @id @default(cuid())
  userId              String
  goalId              String?
  source              String    @default("WEB")
  purpose             String    @default("CHECKIN_EVIDENCE")
  fileName            String
  mimeType            String
  sizeBytes           Int
  checksumSha256      String?
  storageProvider     String    @default("LOCAL_PLACEHOLDER")
  objectKey           String    @unique
  publicUrl           String?   @db.Text
  status              String    @default("READY")
  scanStatus          String    @default("NOT_REQUIRED")
  scanResult          String?   @db.Text
  verifiedMimeType    String?
  verifiedSizeBytes   Int?
  uploadExpiresAt     DateTime?
  scanAttempts        Int       @default(0)
  scanStartedAt       DateTime?
  scanCompletedAt     DateTime?
  deleteAttempts      Int       @default(0)
  deleteError         String?   @db.Text
  lastDeleteAttemptAt DateTime?
  uploadedAt          DateTime?
  deletedAt           DateTime?
  metadata            Json?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal Goal? @relation(fields: [goalId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([goalId, status])
  @@index([source, purpose])
  @@index([status, createdAt])
  @@index([status, uploadExpiresAt])
  @@index([scanStatus, updatedAt])
  @@map("upload_assets")
}

model ObjectDeletionJob {
  id              String    @id @default(cuid())
  storageProvider String
  objectKey       String?   @db.Text
  objectKeyHash   String
  sourceType      String
  sourceId        String?
  status          String    @default("QUEUED")
  attempts        Int       @default(0)
  error           String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  completedAt     DateTime?

  @@unique([storageProvider, objectKeyHash])
  @@index([status, createdAt])
  @@map("object_deletion_jobs")
}

model Membership {
  id        String           @id @default(cuid())
  userId    String           @unique
  plan      MembershipPlan   @default(FREE)
  status    MembershipStatus @default(ACTIVE)
  expiresAt DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("memberships")
}

model Entitlement {
  id         String    @id @default(cuid())
  userId     String
  capability String
  limitValue Int?
  source     String    @default("ADMIN")
  validFrom  DateTime  @default(now())
  validUntil DateTime?
  metadata   Json?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, capability, validFrom, validUntil])
  @@map("entitlements")
}

model UsageRecord {
  id             String    @id @default(cuid())
  userId         String
  capability     String
  quantity       Int       @default(1)
  periodKey      String
  idempotencyKey String    @unique
  resourceType   String?
  resourceId     String?
  metadata       Json?
  releasedAt     DateTime?
  createdAt      DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, capability, periodKey])
  @@index([resourceType, resourceId])
  @@map("usage_records")
}

model QuotaBucket {
  id         String    @id @default(cuid())
  userId     String
  capability String
  periodKey  String
  used       Int       @default(0)
  limitValue Int
  resetAt    DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, capability, periodKey])
  @@index([capability, periodKey])
  @@map("quota_buckets")
}

model PaymentOrder {
  id              String    @id @default(cuid())
  userId          String
  provider        String
  plan            String
  durationDays    Int
  amountCents     Int
  currency        String    @default("CNY")
  status          String    @default("PENDING")
  providerOrderId String?   @unique
  checkoutUrl     String?   @db.Text
  paidAt          DateTime?
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user   User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  events PaymentEvent[]
  audits MembershipAudit[]

  @@index([userId, createdAt])
  @@index([provider, status])
  @@map("payment_orders")
}

model PaymentEvent {
  id              String    @id @default(cuid())
  orderId         String?
  userId          String
  provider        String
  providerEventId String    @unique
  type            String
  payload         Json
  processedAt     DateTime?
  createdAt       DateTime  @default(now())

  order PaymentOrder? @relation(fields: [orderId], references: [id], onDelete: SetNull)
  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([provider, createdAt])
  @@index([orderId, createdAt])
  @@map("payment_events")
}

model MembershipAudit {
  id               String    @id @default(cuid())
  userId           String
  actorUserId      String?
  orderId          String?
  action           String
  fromPlan         String?
  toPlan           String
  fromStatus       String?
  toStatus         String
  expiresAt        DateTime?
  reason           String?   @db.Text
  reasonKeyVersion String?
  metadata         Json
  createdAt        DateTime  @default(now())

  user  User          @relation("MembershipAuditUser", fields: [userId], references: [id], onDelete: Cascade)
  actor User?         @relation("MembershipAuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  order PaymentOrder? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([actorUserId, createdAt])
  @@map("membership_audits")
}

model Goal {
  id                        String       @id @default(cuid())
  userId                    String
  title                     String
  description               String       @db.Text
  descriptionKeyVersion     String?
  category                  GoalCategory @default(CUSTOM)
  status                    GoalStatus   @default(DRAFT)
  startDate                 DateTime
  endDate                   DateTime
  timezone                  String       @default("Asia/Shanghai")
  toleranceDaysAllowed      Int          @default(0)
  toleranceDaysUsed         Int          @default(0)
  dailyTimeBudgetMinutes    Int?
  examName                  String?
  targetScore               String?
  currentScore              String?
  examDate                  DateTime?
  subjects                  Json?
  materials                 Json?
  chapters                  Json?
  weaknesses                Json?
  studyDaysPerWeek          Int?
  dailyStudyMinutes         Int?
  mockExamFrequency         String?
  currentBaseline           String?      @db.Text
  currentBaselineKeyVersion String?
  constraints               String?      @db.Text
  constraintsKeyVersion     String?
  finalReward               String?      @db.Text
  finalRewardKeyVersion     String?
  createdAt                 DateTime     @default(now())
  updatedAt                 DateTime     @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan            Plan?
  milestones      Milestone[]
  dailyTasks      DailyTask[]
  checkins        Checkin[]
  aiJobs          AiJob[]
  deviationEvents DeviationEvent[]
  rewardCards     RewardCard[]
  healthSnapshots HealthSnapshot[]
  reportArtifacts ReportArtifact[]
  failureReport   FailureReport?
  aiCallLogs      AiCallLog[]
  uploadAssets    UploadAsset[]

  @@index([userId, status])
  @@map("goals")
}

model FailureReport {
  id                       String   @id @default(cuid())
  goalId                   String   @unique
  reasonAnalysis           String   @db.Text
  reasonAnalysisKeyVersion String?
  brokenStreakTimeline     Json
  lowScoreTasks            Json
  keyDeviationNodes        Json
  suggestion               String   @db.Text
  suggestionKeyVersion     String?
  restartGoalDraft         Json
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@map("failure_reports")
}

model RewardCard {
  id                    String   @id @default(cuid())
  goalId                String
  title                 String
  description           String?  @db.Text
  descriptionKeyVersion String?
  cardType              String   @default("TEXT")
  sourceType            String   @default("CUSTOM")
  sourceRefId           String?
  imageUrl              String?  @db.Text
  linkUrl               String?  @db.Text
  sortOrder             Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId, sortOrder])
  @@index([goalId, sourceType])
  @@map("reward_cards")
}

model Plan {
  id          String    @id @default(cuid())
  goalId      String    @unique
  version     Int       @default(1)
  summary     String    @db.Text
  isActive    Boolean   @default(false)
  confirmedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  goal        Goal         @relation(fields: [goalId], references: [id], onDelete: Cascade)
  weeklyPlans WeeklyPlan[]

  @@map("plans")
}

model Milestone {
  id          String   @id @default(cuid())
  goalId      String
  title       String
  description String?  @db.Text
  targetDate  DateTime
  rewardText  String?  @db.Text
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId, targetDate])
  @@map("milestones")
}

model WeeklyPlan {
  id        String   @id @default(cuid())
  planId    String
  weekIndex Int
  title     String
  summary   String   @db.Text
  startsOn  DateTime
  endsOn    DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  plan       Plan        @relation(fields: [planId], references: [id], onDelete: Cascade)
  dailyTasks DailyTask[]

  @@unique([planId, weekIndex])
  @@map("weekly_plans")
}

model DailyTask {
  id                String   @id @default(cuid())
  goalId            String
  weeklyPlanId      String?
  sourceDailyTaskId String?
  deviationEventId  String?
  taskDate          DateTime
  title             String
  description       String   @db.Text
  plannedMinutes    Int?
  studyTaskType     String?
  subject           String?
  materialRef       String?  @db.Text
  chapterRef        String?  @db.Text
  questionCount     Int?
  targetAccuracy    Int?
  evidenceRequired  Boolean  @default(false)
  priority          Int?
  taskType          String   @default("NORMAL")
  rescueReason      String?  @db.Text
  rescueTriggerCode String?
  rescueRiskLevel   String?
  status            String   @default("PENDING")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  goal           Goal            @relation(fields: [goalId], references: [id], onDelete: Cascade)
  weeklyPlan     WeeklyPlan?     @relation(fields: [weeklyPlanId], references: [id], onDelete: SetNull)
  deviationEvent DeviationEvent? @relation(fields: [deviationEventId], references: [id], onDelete: SetNull)
  checkins       Checkin[]

  @@index([goalId, taskDate])
  @@index([goalId, taskType, status])
  @@index([goalId, studyTaskType])
  @@index([goalId, subject])
  @@index([sourceDailyTaskId])
  @@index([deviationEventId])
  @@map("daily_tasks")
}

model DeviationEvent {
  id                  String   @id @default(cuid())
  goalId              String
  sourceDailyTaskId   String?
  riskLevel           String
  primaryReasonCode   String?
  primaryReasonLabel  String?
  primaryReasonDetail String?  @db.Text
  reasons             Json
  metrics             Json
  detectedAt          DateTime @default(now())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  goal        Goal        @relation(fields: [goalId], references: [id], onDelete: Cascade)
  rescueTasks DailyTask[]

  @@index([goalId, detectedAt])
  @@index([goalId, riskLevel])
  @@index([sourceDailyTaskId])
  @@map("deviation_events")
}

model HealthSnapshot {
  id                String   @id @default(cuid())
  goalId            String
  date              DateTime
  healthScore       Int
  deviationEventId  String?
  completionMetrics Json
  rescueMetrics     Json
  riskLevel         String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@unique([goalId, date])
  @@index([goalId, date])
  @@index([goalId, riskLevel])
  @@index([deviationEventId])
  @@map("health_snapshots")
}

model ReportArtifact {
  id              String   @id @default(cuid())
  goalId          String
  type            String
  periodStart     DateTime
  periodEnd       DateTime
  title           String
  summary         String   @db.Text
  body            String   @db.LongText
  recommendations Json
  provider        String
  model           String?
  promptVersion   String
  status          String   @default("READY")
  error           String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@unique([goalId, type, periodEnd])
  @@index([goalId, createdAt])
  @@index([status, type])
  @@map("report_artifacts")
}

model Checkin {
  id                        String        @id @default(cuid())
  userId                    String
  goalId                    String
  dailyTaskId               String?
  status                    CheckinStatus @default(SUBMITTED)
  content                   String        @db.Text
  contentKeyVersion         String?
  investedMinutes           Int?
  completedSubtasks         Json?
  actualQuestionCount       Int?
  correctQuestionCount      Int?
  accuracy                  Int?
  evidenceFiles             Json?
  evidenceLinks             Json?
  studyMood                 String?
  studyMoodKeyVersion       String?
  difficultyLevel           String?
  difficultyLevelKeyVersion String?
  submittedAt               DateTime      @default(now())
  createdAt                 DateTime      @default(now())
  updatedAt                 DateTime      @updatedAt

  goal         Goal          @relation(fields: [goalId], references: [id], onDelete: Cascade)
  dailyTask    DailyTask?    @relation(fields: [dailyTaskId], references: [id], onDelete: SetNull)
  aiScore      AiScore?
  scoreAppeals ScoreAppeal[]

  @@index([goalId, submittedAt])
  @@map("checkins")
}

model ScoreAppeal {
  id                   String   @id @default(cuid())
  userId               String
  checkinId            String
  reason               String   @db.Text
  reasonKeyVersion     String?
  addedFacts           String   @db.Text
  addedFactsKeyVersion String?
  status               String   @default("PENDING")
  originalScore        Int
  newScore             Int?
  evidence             Json
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  checkin Checkin @relation(fields: [checkinId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([checkinId, createdAt])
  @@map("score_appeals")
}

model AiScore {
  id         String   @id @default(cuid())
  checkinId  String   @unique
  totalScore Int
  dimensions Json
  evidence   Json
  summary    String   @db.Text
  suggestion String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  checkin Checkin @relation(fields: [checkinId], references: [id], onDelete: Cascade)

  @@map("ai_scores")
}

model AiJob {
  id        String      @id @default(cuid())
  traceId   String?
  userId    String
  goalId    String?
  type      String
  status    AiJobStatus @default(QUEUED)
  attempts  Int         @default(0)
  payload   Json
  result    Json?
  error     String?     @db.Text
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal       Goal?       @relation(fields: [goalId], references: [id], onDelete: SetNull)
  aiCallLogs AiCallLog[]

  @@index([status, type])
  @@index([userId, createdAt])
  @@index([traceId])
  @@map("ai_jobs")
}

model AiCallLog {
  id                  String   @id @default(cuid())
  userId              String
  goalId              String?
  aiJobId             String?
  traceId             String?
  capability          String
  provider            String
  model               String?
  promptVersion       String
  inputHash           String
  requestId           String?
  status              String
  promptTokens        Int?
  completionTokens    Int?
  totalTokens         Int?
  latencyMs           Int
  estimatedCostMicros Int?
  attempt             Int      @default(1)
  errorCategory       String?
  error               String?  @db.Text
  fallbackUsed        Boolean  @default(false)
  createdAt           DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal  Goal?  @relation(fields: [goalId], references: [id], onDelete: SetNull)
  aiJob AiJob? @relation(fields: [aiJobId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([goalId, capability, createdAt])
  @@index([status, errorCategory, createdAt])
  @@index([traceId, createdAt])
  @@map("ai_call_logs")
}
