{
  "name": "@goalmate/api",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "start": "node dist/main.js",
    "start:dev": "tsx watch src/main.ts",
    "start:e2e": "tsx src/main.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:integration": "node --import tsx --test src/**/*.integration.test.ts",
    "prisma:generate": "XDG_CACHE_HOME=../../.cache prisma generate --schema prisma/schema.prisma",
    "prisma:migrate": "XDG_CACHE_HOME=../../.cache prisma migrate dev --schema prisma/schema.prisma",
    "prisma:studio": "XDG_CACHE_HOME=../../.cache prisma studio --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1073.0",
    "@aws-sdk/s3-request-presigner": "^3.1073.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@prisma/client": "^6.19.3",
    "bullmq": "^5.78.0",
    "file-type": "^21.3.4",
    "image-size": "^2.0.2",
    "ioredis": "^5.11.1",
    "pdf-lib": "^1.17.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.0",
    "stripe": "^22.2.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "prisma": "^6.19.3",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
