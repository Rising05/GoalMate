.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--color-primary-light);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
}

.ml-12 {
  margin-left: 24rpx;
}

.quota-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.quota-item {
  background: var(--color-bg);
  border-radius: 12rpx;
  padding: 16rpx;
  text-align: center;
}

.quota-value {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-primary);
  margin-bottom: 4rpx;
}

.quota-label {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.btn-outline-danger {
  background: transparent;
  color: var(--color-danger);
  border: 2rpx solid var(--color-danger);
}
