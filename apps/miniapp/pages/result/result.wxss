.result-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 80rpx;
}

.result-card {
  width: 100%;
  text-align: center;
  padding: 48rpx 24rpx;
}

.result-icon {
  font-size: 80rpx;
  margin-bottom: 8rpx;
}

.score-section {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid var(--color-border);
}

.score-display {
  display: flex;
  align-items: baseline;
  justify-content: center;
}

.score-number {
  font-size: 72rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.score-unit {
  font-size: 32rpx;
  color: var(--color-text-secondary);
  margin-left: 4rpx;
}

.result-actions {
  width: 100%;
  padding: 0 24rpx;
}
